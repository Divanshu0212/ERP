# Copy to infra/.env for local dev. This file is loaded automatically by
# docker compose (it lives next to docker-compose.yml) for ${VAR} substitution.
# infra/.env itself is gitignored — never commit real keys.

# Razorpay test-mode keys (dashboard.razorpay.com -> Settings -> API Keys).
# Used by finance-service (fee payments) and canteen-service (order payments).
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
