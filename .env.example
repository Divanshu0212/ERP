# SU-ERP environment variables (copy to .env per service; local-Docker defaults shown)

# --- Core config ---
DEBUG=1

# --- JWT (shared across all services; zero-trust signature verification) ---
# Generate a strong key for staging/prod; this default is dev-only.
JWT_SIGNING_KEY=dev-insecure-change-me

# --- Postgres (via PgBouncer in the local stack) ---
# Each service points at its own logical database.
# Local Docker default: postgres://suerp:suerp@pgbouncer:6432/<service_db>
# Absent -> service falls back to a local sqlite file (dev only).
DATABASE_URL=postgres://suerp:suerp@pgbouncer:6432/auth
# Optional read replica alias; defaults to DATABASE_URL if unset.
READ_DATABASE_URL=

# --- Redis (cache + rate-limit + Celery broker/result) ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ (event bus) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Gateway base URL (used by ai-service chatbot + frontend) ---
GATEWAY_URL=http://gateway:8080
