{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://suerp/event-schemas/hostel.allocation.confirmed.json",
  "title": "hostel.allocation.confirmed",
  "description": "Emitted by hostel-service after a successful payment confirms the seat (saga step 5). notification-service writes the student's inbox message.",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "type", "tenant_id", "occurred_at", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "type": { "const": "hostel.allocation.confirmed" },
    "tenant_id": { "type": "string" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allocation_id", "student_user_code", "room_id"],
      "properties": {
        "allocation_id": { "type": "string", "format": "uuid" },
        "student_user_code": { "type": "string", "maxLength": 30 },
        "room_id": { "type": "string", "format": "uuid" }
      }
    }
  }
}
