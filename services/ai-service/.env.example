# ai-service environment variables (copy to .env for local dev)
#
# ai-service is a stateless FastAPI service (no database). It verifies JWTs
# itself, consumes grievance.created and produces grievance.scored on the bus,
# and calls owning services through the gateway for the chatbot.

# --- JWT (shared across all services; zero-trust signature verification) ---
# Generate a strong key for staging/prod; this default is dev-only.
JWT_SIGNING_KEY=dev-insecure-change-me

# --- RabbitMQ (event bus) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Gateway base URL (chatbot calls owning services through it) ---
GATEWAY_URL=http://gateway:8080
