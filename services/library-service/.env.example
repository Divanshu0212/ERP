# library-service environment variables (copy to .env for local dev)

# --- Core config ---
SECRET_KEY=dev-insecure-secret-key-change-me
DEBUG=1
ALLOWED_HOSTS=*

# --- JWT (shared across all services; zero-trust signature verification) ---
# Generate a strong key for staging/prod; this default is dev-only.
JWT_SIGNING_KEY=dev-insecure-change-me

# --- Postgres (via PgBouncer in the local stack) ---
# Absent -> service falls back to a local sqlite file (dev only).
DATABASE_URL=postgres://suerp:suerp@pgbouncer:6432/library
# Optional read replica alias; defaults to DATABASE_URL if unset.
READ_DATABASE_URL=

# --- Redis (cache + Celery broker/result) ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ (event bus) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
