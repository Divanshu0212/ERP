{
    "terminal.integrated.profiles.linux": {
        "fish": {
            "path": "/usr/bin/flatpak-spawn",
            "args": [
                "--host",
                "--env=TERM=xterm-256color",
                "/bin/fish",
                "-l"
            ],
            "icon": "terminal"
        }
